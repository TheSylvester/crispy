{
  "name": "crispy-code",
  "displayName": "Crispy",
  "icon": "media/crispy-icon.png",
  "description": "An agent workbench for Claude Code and Codex — with local agent memory, multi-agent collaboration, and controls you can't get in a terminal",
  "version": "0.2.4-rc22",
  "publisher": "the-sylvester",
  "license": "MIT",
  "bin": {
    "crispy": "./dist/crispy-cli.js"
  },
  "author": "Sylvester Wong",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheSylvester/crispy.git"
  },
  "homepage": "https://github.com/TheSylvester/crispy",
  "bugs": {
    "url": "https://github.com/TheSylvester/crispy/issues"
  },
  "qna": "https://discord.gg/e2vw4bTPup",
  "badges": [
    {
      "url": "https://img.shields.io/discord/1483243664389177479?color=5865F2&logo=discord&logoColor=white&label=Discord",
      "href": "https://discord.gg/e2vw4bTPup",
      "description": "Join the Crispy Discord"
    }
  ],
  "keywords": [
    "ai",
    "claude",
    "codex",
    "opencode",
    "agent",
    "coding-assistant",
    "vscode"
  ],
  "files": [
    "dist/",
    "media/crispy-icon.png",
    "media/crispy-icon.svg",
    "LICENSE",
    "THIRD-PARTY-LICENSES",
    "README.md"
  ],
  "engines": {
    "node": ">=18",
    "vscode": "^1.94.0"
  },
  "main": "./dist/extension.js",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/sdk": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.2.20",
    "extract-zip": "^2.0.1",
    "node-sqlite3-wasm": "^0.8.53",
    "open": "^10.2.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "onnxruntime-node": "1.21.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.94.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "postinstall": "node -e \"try{require('fs').accessSync('scripts/ensure-sharp-stub.mjs');require('child_process').execSync('node scripts/ensure-sharp-stub.mjs',{stdio:'ignore'})}catch{}\"",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:onnxruntime-node --external:@huggingface/transformers --format=cjs --platform=node --sourcemap --loader:.md=text && cp node_modules/node-sqlite3-wasm/dist/node-sqlite3-wasm.wasm dist/ && cp src/core/rosie/tracker/crispy-tracker.mjs dist/",
    "build:webview": "esbuild src/webview/main.tsx --bundle --outfile=dist/webview/main.js --format=esm --platform=browser --sourcemap --jsx=automatic --loader:.svg=text && cp src/webview/index.html dist/webview/ && cp src/webview/theme-defaults.css dist/webview/ && cp src/webview/styles.css dist/webview/ && cp media/favicon.png dist/webview/",
    "build:dev-server": "esbuild src/host/dev-server.ts --bundle --outfile=dist/dev-server.js --external:@anthropic-ai/* --external:ws --external:onnxruntime-node --external:@huggingface/transformers --format=esm --platform=node --sourcemap --loader:.md=text && cp node_modules/node-sqlite3-wasm/dist/node-sqlite3-wasm.wasm dist/ && cp src/core/rosie/tracker/crispy-tracker.mjs dist/",
    "build:crispy-plugin": "rm -rf dist/crispy-plugin && cp -r src/plugin dist/crispy-plugin",
    "build": "npm run build:extension && npm run build:webview && npm run build:dev-server && npm run build:recall && npm run build:cli && npm run build:cli-entry && npm run build:crispy-plugin",
    "watch": "npm run build:extension -- --watch",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && vsce package",
    "package:linux-x64": "npm run build && node scripts/package-vsix.mjs linux-x64",
    "package:linux-arm64": "npm run build && node scripts/package-vsix.mjs linux-arm64",
    "package:darwin-x64": "npm run build && node scripts/package-vsix.mjs darwin-x64",
    "package:darwin-arm64": "npm run build && node scripts/package-vsix.mjs darwin-arm64",
    "package:win32-x64": "npm run build && node scripts/package-vsix.mjs win32-x64",
    "package:win32-arm64": "npm run build && node scripts/package-vsix.mjs win32-arm64",
    "test": "./scripts/check-claude-fixture.sh",
    "test:unit": "vitest run",
    "smoke": "npx tsx scripts/smoke.ts",
    "smoke:quick": "npx tsx scripts/smoke.ts --skip-embed",
    "dev": "npm run build:webview && node --import tsx src/host/dev-server.ts",
    "build:cli": "esbuild src/cli/crispy-dispatch.ts --bundle --outfile=dist/crispy-dispatch.js --format=esm --platform=node --sourcemap --banner:js=\"#!/usr/bin/env node\" && chmod +x dist/crispy-dispatch.js",
    "build:cli-entry": "esbuild src/cli/crispy-cli.ts --bundle --outfile=dist/crispy-cli.js --external:@anthropic-ai/* --external:ws --external:open --external:onnxruntime-node --external:@huggingface/transformers --format=cjs --platform=node --sourcemap --loader:.md=text --banner:js=\"#!/usr/bin/env node\"",
    "build:recall": "esbuild scripts/recall.ts --bundle --outfile=dist/recall.js --external:onnxruntime-node --external:@huggingface/transformers --format=cjs --platform=node --sourcemap --banner:js=\"#!/usr/bin/env node\" && chmod +x dist/recall.js",
    "dispatch": "node --import tsx src/cli/crispy-dispatch.ts",
    "prepublishOnly": "npm run build"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onWebviewPanel:crispy"
  ],
  "contributes": {
    "commands": [
      {
        "command": "crispy.editor.open",
        "title": "Crispy: Open",
        "icon": {
          "light": "media/crispy-icon.svg",
          "dark": "media/crispy-icon.svg"
        }
      },
      {
        "command": "crispy.executeFile",
        "title": "Execute in Crispy"
      },
      {
        "command": "crispy.focus",
        "title": "Crispy: Focus Input"
      },
      {
        "command": "crispy.blur",
        "title": "Crispy: Focus Editor"
      },
      {
        "command": "crispy.toggleVoiceInput",
        "title": "Crispy: Toggle Voice Input"
      }
    ],
    "keybindings": [
      {
        "command": "crispy.editor.open",
        "key": "ctrl+shift+alt+i",
        "mac": "cmd+shift+alt+i"
      },
      {
        "command": "crispy.focus",
        "key": "ctrl+;",
        "mac": "cmd+;",
        "when": "editorTextFocus"
      },
      {
        "command": "crispy.blur",
        "key": "ctrl+;",
        "mac": "cmd+;",
        "when": "!editorTextFocus && activeWebviewPanelId == 'crispy'"
      },
      {
        "command": "crispy.toggleVoiceInput",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "activeWebviewPanelId == 'crispy' && webviewFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "crispy.editor.open",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "crispy.executeFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "crispy.executeFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Untrusted workspaces are not supported"
    }
  }
}
