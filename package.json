{
  "name": "crispy",
  "displayName": "Crispy",
  "description": "Open-source Claude Code UI for VS Code and Cursor",
  "version": "0.0.1",
  "publisher": "TheSylvester",
  "license": "MIT",
  "engines": {
    "vscode": "^1.94.0"
  },
  "main": "./dist/extension.js",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.32",
    "@anthropic-ai/sdk": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "scripts": {
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:webview": "esbuild src/webview/main.tsx --bundle --outfile=dist/webview/main.js --format=esm --platform=browser --sourcemap --jsx=automatic && cp src/webview/index.html dist/webview/ && cp src/webview/theme-defaults.css dist/webview/ && cp src/webview/styles.css dist/webview/",
    "build:dev-server": "esbuild src/host/dev-server.ts --bundle --outfile=dist/dev-server.js --external:@anthropic-ai/* --external:ws --format=esm --platform=node --sourcemap",
    "build": "npm run build:extension && npm run build:webview && npm run build:dev-server",
    "watch": "npm run build:extension -- --watch",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && vsce package",
    "test": "./scripts/check-claude-fixture.sh",
    "test:unit": "vitest run",
    "dev": "npm run build:webview && node --import tsx src/host/dev-server.ts"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "crispy.open",
        "title": "Open Crispy"
      }
    ],
    "keybindings": [
      {
        "command": "crispy.open",
        "key": "ctrl+shift+alt+i",
        "mac": "cmd+shift+alt+i"
      }
    ],
    "configuration": {
      "title": "Crispy",
      "properties": {}
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Untrusted workspaces are not supported"
    }
  }
}
