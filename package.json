{
  "name": "crispy",
  "displayName": "Crispy",
  "icon": "media/crispy-icon.png",
  "description": "A zero-compromise UI for Claude Code, Codex, and more — with controls you can't get in a terminal",
  "version": "0.1.4-dev.30",
  "publisher": "the-sylvester",
  "private": true,
  "license": "MIT",
  "author": "Sylvester Wong",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheSylvester/crispy.git"
  },
  "homepage": "https://github.com/TheSylvester/crispy",
  "bugs": {
    "url": "https://github.com/TheSylvester/crispy/issues"
  },
  "keywords": [
    "ai",
    "claude",
    "codex",
    "opencode",
    "agent",
    "coding-assistant",
    "vscode"
  ],
  "engines": {
    "vscode": "^1.94.0"
  },
  "main": "./dist/extension.js",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@anthropic-ai/sdk": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "node-sqlite3-wasm": "^0.8.53",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.94.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "scripts": {
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap && cp node_modules/node-sqlite3-wasm/dist/node-sqlite3-wasm.wasm dist/",
    "build:webview": "esbuild src/webview/main.tsx --bundle --outfile=dist/webview/main.js --format=esm --platform=browser --sourcemap --jsx=automatic --loader:.svg=text && cp src/webview/index.html dist/webview/ && cp src/webview/theme-defaults.css dist/webview/ && cp src/webview/styles.css dist/webview/",
    "build:dev-server": "esbuild src/host/dev-server.ts --bundle --outfile=dist/dev-server.js --external:@anthropic-ai/* --external:ws --format=esm --platform=node --sourcemap",
    "build:internal-mcp": "esbuild src/mcp/servers/internal-main.ts --bundle --outfile=dist/internal-mcp.js --format=cjs --platform=node --sourcemap",
    "build": "npm run build:extension && npm run build:webview && npm run build:dev-server && npm run build:internal-mcp",
    "watch": "npm run build:extension -- --watch",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && vsce package",
    "test": "./scripts/check-claude-fixture.sh",
    "test:unit": "vitest run",
    "dev": "npm run build:webview && node --import tsx src/host/dev-server.ts"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onWebviewPanel:crispy"
  ],
  "contributes": {
    "commands": [
      {
        "command": "crispy.editor.open",
        "title": "Crispy: Open",
        "icon": {
          "light": "media/crispy-icon.svg",
          "dark": "media/crispy-icon.svg"
        }
      },
      {
        "command": "crispy.executeFile",
        "title": "Execute in Crispy"
      },
      {
        "command": "crispy.focus",
        "title": "Crispy: Focus Input"
      },
      {
        "command": "crispy.blur",
        "title": "Crispy: Focus Editor"
      }
    ],
    "keybindings": [
      {
        "command": "crispy.editor.open",
        "key": "ctrl+shift+alt+i",
        "mac": "cmd+shift+alt+i"
      },
      {
        "command": "crispy.focus",
        "key": "ctrl+;",
        "mac": "cmd+;",
        "when": "editorTextFocus"
      },
      {
        "command": "crispy.blur",
        "key": "ctrl+;",
        "mac": "cmd+;",
        "when": "!editorTextFocus && activeWebviewPanelId == 'crispy'"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "crispy.editor.open",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "crispy.executeFile",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Untrusted workspaces are not supported"
    }
  }
}
