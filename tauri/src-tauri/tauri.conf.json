{
  "productName": "Crispy",
  "version": "0.3.2-rc.3",
  "identifier": "io.github.thesylvester.crispy",
  "build": {
    "frontendDist": "../src-frontend/"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "runtime/**/*"
    ],
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/TheSylvester/crispy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0MjAxQzc3NjYxN0U3MkMKUldRczV4ZG1keHdnRlBlOHV2ckt6RHhmQUZ4Wk9BN2tNdTdYWTdxb2pMOU5oVnhMV29XbHAveHkK"
    }
  }
}
