#!/usr/bin/env bash
# rosie-lab — fork a session at a turn, inject a prompt, see what comes back.
# No persistence, no side effects.
set -euo pipefail

SUPER_AGENT="${HOME}/.claude/skills/super-agent/scripts/super-agent"

# ── Args ────────────────────────────────────────────────────────────────────
if [ $# -lt 2 ]; then
  echo "Usage: rosie-lab <session-id> <turn-or-uuid> [--model <model>] [--prompt-file <path> | inline prompt...]" >&2
  exit 1
fi

SESSION_ID="$1"; shift
TURN_OR_UUID="$1"; shift

# Scan remaining args for flags; collect the rest as inline prompt
PROMPT_FILE_ARG=""
MODEL="claude-haiku-4-5"
INLINE_PARTS=()
while [ $# -gt 0 ]; do
  case "$1" in
    --prompt-file)
      shift
      PROMPT_FILE_ARG="${1:?--prompt-file requires a path}"
      shift
      ;;
    --model)
      shift
      MODEL="${1:?--model requires a value}"
      shift
      ;;
    *)
      INLINE_PARTS+=("$1")
      shift
      ;;
  esac
done

# ── Resolve JSONL & full session ID ─────────────────────────────────────────
JSONL=$(find ~/.claude/projects -name "*${SESSION_ID}*.jsonl" 2>/dev/null | head -1)
if [ -z "$JSONL" ]; then
  echo "Error: No JSONL file found for session $SESSION_ID" >&2
  exit 1
fi
# Extract full UUID from filename (e.g. "3d0cc977-0cb8-4bfb-8df2-04556b6bf8f0")
FULL_SESSION_ID=$(basename "$JSONL" .jsonl)

# ── Resolve UUID ────────────────────────────────────────────────────────────
if [[ "$TURN_OR_UUID" =~ ^[0-9]+$ ]]; then
  # Pure integer → turn number; resolve to UUID
  TURN_NUM="$TURN_OR_UUID"
  MESSAGE_UUID=$(python3 -c "
import json, sys
n = int(sys.argv[1])
count = 0
for line in open(sys.argv[2]):
    obj = json.loads(line)
    if obj.get('type') == 'user' and not obj.get('sourceToolAssistantUUID'):
        count += 1
        if count == n:
            print(obj['uuid'])
            sys.exit(0)
print(f'Error: only {count} human turns found, requested turn {n}', file=sys.stderr)
sys.exit(1)
" "$TURN_NUM" "$JSONL")
  echo "Turn $TURN_NUM → UUID $MESSAGE_UUID" >&2
else
  MESSAGE_UUID="$TURN_OR_UUID"
fi

# ── Determine prompt ───────────────────────────────────────────────────────
TMPFILE=$(mktemp /tmp/rosie-lab-XXXXXX.md)
trap "rm -f '$TMPFILE'" EXIT

if [ -n "$PROMPT_FILE_ARG" ]; then
  cp "$PROMPT_FILE_ARG" "$TMPFILE"
elif [ ${#INLINE_PARTS[@]} -gt 0 ]; then
  printf '%s\n' "${INLINE_PARTS[*]}" > "$TMPFILE"
else
  # Built-in default: current Rosie prompt + <status> field
  cat > "$TMPFILE" << 'ROSIE'
Consider this entire conversation so far.
What is the stated or apparent goal of this particular conversation?
How would you label this conversation in a short sentence for a user to best remember what this session was for?
Summarize the last turn: Describe the User Request and your Response; including any work completed
What is the current status of the work in this conversation? Describe where things stand right now — what's done, what's in progress, what's blocked or paused.

Provide your output in this format:
<goal>The goal of this conversation</goal>
<title>Label the conversation</title>
<summary>Turn summary</summary>
<status>Current status of the work</status>
ROSIE
fi

# ── Invoke super-agent ──────────────────────────────────────────────────────
# Capture stderr to find the output_file path (super-agent prints it there)
SA_STDERR=$(mktemp /tmp/rosie-lab-stderr-XXXXXX)
trap "rm -f '$TMPFILE' '$SA_STDERR'" EXIT

PROMPT_FILE="$TMPFILE" \
SUPER_AGENT_MODEL="$MODEL" \
  "$SUPER_AGENT" \
  --fork --resume "$FULL_SESSION_ID" --resume-at "$MESSAGE_UUID" \
  --no-persist --no-chrome 2>"$SA_STDERR" || true

# If stdout was empty (sandbox buffering), cat the output file
OUTPUT_LOG=$(grep -oP '(?<=\[output_file: ).*(?=\])' "$SA_STDERR" || true)
if [ -n "$OUTPUT_LOG" ] && [ -f "$OUTPUT_LOG" ]; then
  cat "$OUTPUT_LOG"
fi
# Show cost/session info from stderr
grep -E '^\[(Cost|Session|Agent)' "$SA_STDERR" >&2 || true
