#!/usr/bin/env bash
# crispy-agent: Unified wrapper around crispy-dispatch for multi-vendor IPC dispatch.
#
# Usage:
#   crispy-agent <prompt>                              # Args as prompt (default: claude)
#   crispy-agent --vendor codex <prompt>               # Dispatch via codex
#   crispy-agent --model <model> <prompt>              # Specify model
#   crispy-agent --resume <UUID> <prompt>              # Resume session by UUID
#   PROMPT_FILE=task.md crispy-agent                   # Read from file
#   cat task.md | crispy-agent                         # Read from stdin
#
# Environment variables:
#   PROMPT_FILE          - Read prompt from this file
#   CRISPY_SOCK          - Override socket path (skip discovery)
#   BYPASS_PERMISSIONS   - Set to 1 for --approval bypass

set -euo pipefail

OUTPUT_DIR="/tmp/crispy-agents"

# Resolve repo root from script location: scripts/ → crispy-agent/ → skills/ → .claude/ → repo
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
DISPATCH_BIN="node --import tsx ${REPO_ROOT}/src/cli/crispy-dispatch.ts"

# Defaults
VENDOR="claude"
MODEL=""
RESUME=""
APPROVAL="bypass"
TIMEOUT=""
AUTO_CLOSE="--no-auto-close"
VISIBLE=""
FORK=""
RESUME_AT=""
PERSIST=""
DEBUG=""
EXTRA_FLAGS=()

# Parse flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    --vendor)
      VENDOR="$2"
      shift 2
      ;;
    --model|-m)
      MODEL="$2"
      shift 2
      ;;
    --resume|-r)
      RESUME="$2"
      shift 2
      ;;
    --timeout)
      TIMEOUT="$2"
      shift 2
      ;;
    --no-auto-close)
      AUTO_CLOSE="--no-auto-close"
      shift
      ;;
    --auto-close)
      AUTO_CLOSE=""
      shift
      ;;
    --visible)
      VISIBLE="--visible"
      shift
      ;;
    --fork|-f)
      FORK="--fork"
      shift
      ;;
    --resume-at)
      RESUME_AT="$2"
      shift 2
      ;;
    --persist)
      PERSIST="--persist"
      shift
      ;;
    --approval)
      APPROVAL="$2"
      shift 2
      ;;
    --debug)
      DEBUG="--debug"
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

# Determine prompt source: PROMPT_FILE > args > stdin
HAS_STDIN=false
[[ ! -t 0 ]] && HAS_STDIN=true

if [[ -n "${PROMPT_FILE:-}" ]]; then
  PROMPT="$(cat "$PROMPT_FILE")"
elif [[ $# -gt 0 ]]; then
  PROMPT="$*"
elif [[ "$HAS_STDIN" == "true" ]]; then
  PROMPT="$(cat || true)"
else
  echo "Usage: crispy-agent [--vendor <vendor>] [--model <model>] [--resume <UUID>] <prompt>" >&2
  echo "       PROMPT_FILE=task.md crispy-agent" >&2
  echo "       cat task.md | crispy-agent" >&2
  exit 1
fi

# Validate prompt
if [[ -z "${PROMPT//[$' \t\r\n']/}" ]]; then
  echo "Error: prompt is empty" >&2
  exit 1
fi

# Check prerequisite: Crispy host must be running
if [[ -z "${CRISPY_SOCK:-}" ]]; then
  SERVERS_FILE="$HOME/.crispy/ipc/servers.json"
  if [[ ! -f "$SERVERS_FILE" ]]; then
    echo "Error: No Crispy host detected. Start Crispy first." >&2
    echo "  (Expected $SERVERS_FILE or CRISPY_SOCK env var)" >&2
    exit 12
  fi
fi

# Build crispy-dispatch command
CMD=($DISPATCH_BIN)
CMD+=(--vendor "$VENDOR")
CMD+=(--approval "$APPROVAL")

[[ -n "$MODEL" ]] && CMD+=(-m "$MODEL")
[[ -n "$RESUME" ]] && CMD+=(-r "$RESUME")
[[ -n "$TIMEOUT" ]] && CMD+=(--timeout "$TIMEOUT")
[[ -n "$AUTO_CLOSE" ]] && CMD+=("$AUTO_CLOSE")
[[ -n "$VISIBLE" ]] && CMD+=("$VISIBLE")
[[ -n "$FORK" ]] && CMD+=("$FORK")
[[ -n "$RESUME_AT" ]] && CMD+=(--resume-at "$RESUME_AT")
[[ -n "$PERSIST" ]] && CMD+=("$PERSIST")
[[ -n "$DEBUG" ]] && CMD+=("$DEBUG")

# Set up persistent output file
mkdir -p "$OUTPUT_DIR"
OUTPUT_FILE="${OUTPUT_DIR}/crispy-agent-$(date +%s)-$$.log"
echo "[output_file: $OUTPUT_FILE]" >&2

# Write prompt to a temp file for PROMPT_FILE passthrough
PROMPT_TMPFILE=$(mktemp /tmp/crispy-agent-prompt-XXXXXX.md)
echo "$PROMPT" > "$PROMPT_TMPFILE"
trap 'rm -f "$PROMPT_TMPFILE"' EXIT

# Run crispy-dispatch, capture stdout and stderr separately
STDERR_FILE=$(mktemp /tmp/crispy-agent-stderr-XXXXXX)
OUTPUT=$(PROMPT_FILE="$PROMPT_TMPFILE" "${CMD[@]}" 2>"$STDERR_FILE") || {
  EXIT_CODE=$?
  STDERR_CONTENT=$(cat "$STDERR_FILE")
  rm -f "$STDERR_FILE"

  # Still try to extract session ID from stderr metadata
  SESSION_ID=""
  if [[ -n "$STDERR_CONTENT" ]]; then
    SESSION_ID=$(echo "$STDERR_CONTENT" | grep -oP '"sessionId"\s*:\s*"\K[^"]+' | tail -1 || true)
    echo "$STDERR_CONTENT" >&2
  fi

  # Write whatever output we got
  if [[ -n "$OUTPUT" ]]; then
    echo "$OUTPUT"
    echo "$OUTPUT" > "$OUTPUT_FILE"
  fi
  [[ -n "$SESSION_ID" ]] && echo "" && echo "[session_id: $SESSION_ID]"

  exit $EXIT_CODE
}

STDERR_CONTENT=$(cat "$STDERR_FILE")
rm -f "$STDERR_FILE"

# Extract session ID from stderr JSON metadata
SESSION_ID=""
if [[ -n "$STDERR_CONTENT" ]]; then
  SESSION_ID=$(echo "$STDERR_CONTENT" | grep -oP '"sessionId"\s*:\s*"\K[^"]+' | tail -1 || true)
  # Forward non-metadata stderr lines
  echo "$STDERR_CONTENT" | grep -v '^{' >&2 || true
fi

# Output response text
if [[ -n "$OUTPUT" ]]; then
  echo "$OUTPUT"
fi

# Output session ID (matching super-agent/codex-agent convention)
if [[ -n "$SESSION_ID" ]]; then
  echo ""
  echo "[session_id: $SESSION_ID]"
fi

# Write to persistent output file
{
  [[ -n "$OUTPUT" ]] && echo "$OUTPUT"
  [[ -n "$SESSION_ID" ]] && echo "" && echo "[session_id: $SESSION_ID]"
} > "$OUTPUT_FILE"
