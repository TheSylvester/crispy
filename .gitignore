# Track .claude/commands (overrides global gitignore)
!.claude/
!.claude/*
!CLAUDE.md

# Dependencies
node_modules/

# Build output
out/
dist/
*.vsix

# Compiled webview assets (built from webview/)
media/app.js
media/app.js.map

# Local AI reference files (not committed)
.ai-reference/

# Editor/IDE
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

.claude/settings.local.json

